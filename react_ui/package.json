{
  "name": "the-infinite-crate",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "init": "bash ../scripts/initialize.sh",
    "dev": "vite --config config/vite.config.ts",
    "compile": "tsc -b config/tsconfig.app.json && vite build --config config/vite.config.ts && rm ../resources/dom/magenta.png",
    "lint": "eslint --config config/eslint.config.js .",
    "format": "prettier --config config/.prettierrc.js --ignore-path ./config/.prettierignore --write .",
    "preview": "vite preview --config config/vite.config.ts",
    "generate": "npx tsx --tsconfig config/tsconfig.scripts.json ../scripts/generate.ts --config config/tsconfig.scripts.json",
    "codesign": "bash ../scripts/codesign.sh"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-menubar": "^1.1.4",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slider": "^1.2.2",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-toggle": "^1.1.1",
    "@radix-ui/react-toggle-group": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@types/node": "20.12.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint-config-prettier": "^9.1.0",
    "lucide-react": "^0.469.0",
    "prettier": "^3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.16.5",
    "vite-plugin-svgr": "^4.3.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.15.0",
    "vite": "^6.0.1"
  }
}
